#!/usr/bin/env bash
# Mock gpg for card task testing. Intercepts card-related subcommands,
# passes everything else through to real gpg.
set -euo pipefail

MOCK_GPG_STATE_DIR="${MOCK_GPG_STATE_DIR:?MOCK_GPG_STATE_DIR must be set}"
MOCK_GPG_REAL="${MOCK_GPG_REAL:?MOCK_GPG_REAL must be set}"

case "$*" in
    *--card-status*)
        if [[ -f "$MOCK_GPG_STATE_DIR/provisioned" ]]; then
            cat "$MOCK_GPG_STATE_DIR/card-status-provisioned.txt"
        elif [[ -f "$MOCK_GPG_STATE_DIR/setup-done" ]]; then
            cat "$MOCK_GPG_STATE_DIR/card-status-setup.txt"
        else
            cat "$MOCK_GPG_STATE_DIR/card-status-factory.txt"
        fi
        ;;
    *--edit-card*)
        stdin_capture="$(cat)"
        if echo "$stdin_capture" | grep -q "factory-reset"; then
            rm -f "$MOCK_GPG_STATE_DIR/setup-done" "$MOCK_GPG_STATE_DIR/provisioned"
        elif echo "$stdin_capture" | grep -q "passwd"; then
            touch "$MOCK_GPG_STATE_DIR/setup-done"
        fi
        ;;
    *--edit-key*)
        cat > /dev/null
        touch "$MOCK_GPG_STATE_DIR/provisioned"
        ;;
    *--with-colons*--list-keys*)
        cat "$MOCK_GPG_STATE_DIR/list-keys-colon.txt"
        ;;
    *-K*)
        if [[ -f "$MOCK_GPG_STATE_DIR/provisioned" ]]; then
            cat "$MOCK_GPG_STATE_DIR/secret-keys-stub.txt"
        else
            cat "$MOCK_GPG_STATE_DIR/secret-keys-local.txt"
        fi
        ;;
    *)
        exec "$MOCK_GPG_REAL" "$@"
        ;;
esac
