#!/usr/bin/env bash
#MISE description="Run shellcheck on all src/ scripts"
set -euo pipefail

SRC_DIR="${YK_GPG_SRC_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/src}"

echo "Running shellcheck on src/ scripts..."

files=()

# Library files
for f in "${SRC_DIR}"/lib/*.sh; do
    [[ -f "$f" ]] && files+=("$f")
done

# Mise task scripts
for dir in gpg card yubikey setup tails; do
    if [[ -d "${SRC_DIR}/mise-tasks/${dir}" ]]; then
        for f in "${SRC_DIR}/mise-tasks/${dir}"/*; do
            [[ -f "$f" ]] && files+=("$f")
        done
    fi
done

# install-mise.sh
[[ -f "${SRC_DIR}/install-mise.sh" ]] && files+=("${SRC_DIR}/install-mise.sh")

if [[ ${#files[@]} -eq 0 ]]; then
    echo "No files to check"
    exit 1
fi

echo "Checking ${#files[@]} files..."
shellcheck "${files[@]}"
echo "All files passed shellcheck"
