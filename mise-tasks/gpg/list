#!/usr/bin/env bash
#MISE description="List all managed GPG identities and their status"
set -euo pipefail

source "$MISE_PROJECT_ROOT/lib/common.sh"

# Use persistent GNUPGHOME
export GNUPGHOME="$PERSISTENT_GNUPGHOME"
if [[ ! -d "$GNUPGHOME" ]]; then
    warn "Persistent GNUPGHOME not found: $GNUPGHOME"
    warn "No identities to list."
    exit 0
fi

echo ""
echo "=== Managed GPG Identities ==="
echo ""

NOW="$(date +%s)"
WARN_THRESHOLD=$((90 * 86400))  # 90 days in seconds

# Parse secret keys
gpg --with-colons --list-secret-keys 2>/dev/null | while IFS=: read -r type trust _len algo keyid created expires _rest; do
    case "$type" in
        sec)
            echo "---"
            # Get UID for this key
            uid="$(gpg --with-colons --list-secret-keys "$keyid" 2>/dev/null | grep '^uid:' | head -1 | cut -d: -f10)"
            fp="$(gpg --with-colons --list-secret-keys "$keyid" 2>/dev/null | grep '^fpr:' | head -1 | cut -d: -f10)"
            echo "Identity:    $uid"
            echo "Key ID:      0x${keyid}"
            echo "Fingerprint: $fp"
            echo "Algorithm:   $algo"
            if [[ -n "$created" ]]; then
                echo "Created:     $(date -d "@$created" +%Y-%m-%d 2>/dev/null || echo "$created")"
            fi

            # Check metadata for YubiKey info
            if [[ -n "$fp" && -f "${IDENTITIES_DIR}/${fp}.json" ]]; then
                meta="$(cat "${IDENTITIES_DIR}/${fp}.json")"
                yk_serial="$(echo "$meta" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('yubikey_serial',''))" 2>/dev/null || true)"
                if [[ -n "$yk_serial" ]]; then
                    echo "YubiKey:     serial $yk_serial"
                fi
            fi
            ;;
        ssb)
            # Subkey info
            status=""
            if [[ -n "$expires" && "$expires" -gt 0 ]]; then
                exp_date="$(date -d "@$expires" +%Y-%m-%d 2>/dev/null || echo "$expires")"
                remaining=$((expires - NOW))
                if [[ $remaining -le 0 ]]; then
                    status=" \033[1;31m[EXPIRED]\033[0m"
                elif [[ $remaining -le $WARN_THRESHOLD ]]; then
                    days=$((remaining / 86400))
                    status=" \033[1;33m[expires in ${days}d]\033[0m"
                fi
                printf "  Subkey:    %s  algo:%s  expires:%s%b\n" "$keyid" "$algo" "$exp_date" "$status"
            else
                printf "  Subkey:    %s  algo:%s  expires:never\n" "$keyid" "$algo"
            fi
            ;;
    esac
done

echo ""
echo "---"

# Show YubiKey status if connected
if ykman info &>/dev/null 2>&1; then
    echo ""
    echo "=== Connected YubiKey ==="
    detect_yubikey
    echo ""
    gpg --card-status 2>/dev/null | grep -E '(Name|Serial|Signature key|Encryption key|Authentication key)' || true
fi

echo ""
