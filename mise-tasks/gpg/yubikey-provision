#!/usr/bin/env bash
#MISE description="Transfer GPG subkeys to YubiKey card"
#USAGE arg "keyid" help="Key ID to provision onto YubiKey"
set -euo pipefail

source "$MISE_PROJECT_ROOT/lib/common.sh"

KEYID="${usage_keyid:?Key ID argument required}"

check_deps
detect_yubikey

# Verify key exists
KEYFP="$(gpg --with-colons --list-keys "$KEYID" 2>/dev/null | grep '^fpr:' | head -1 | cut -d: -f10)"
if [[ -z "$KEYFP" ]]; then
    error "Key not found: $KEYID"
    exit 1
fi

info "Preparing to transfer key $KEYID onto YubiKey ${YUBIKEY_MODEL} (serial: ${YUBIKEY_SERIAL})"

# Pre-flight card check
echo ""
info "Current card status:"
gpg --card-status 2>/dev/null || warn "Card status not available"
echo ""

echo "Are the PINs currently at factory defaults?"
echo "  (Admin PIN: 12345678, User PIN: 123456)"
echo ""
if confirm "PINs are at factory defaults?" "y"; then
    error "Run 'mise run gpg:yubikey-setup' first to configure PINs before transferring keys."
    error "Transferring keys to a YubiKey with default PINs is a security risk."
    exit 1
fi

# Prompt for Admin PIN
echo ""
read -r -s -p "Enter YubiKey Admin PIN: " ADMIN_PIN
echo ""

# Prompt for certify key passphrase
read -r -s -p "Enter certify key passphrase: " CERTIFY_PASS
echo ""

# Confirm destructive transfer
echo ""
warn "This is a destructive operation - subkeys will be MOVED to the card"
warn "(the local copy becomes a stub)"

if ! confirm "Transfer subkeys to YubiKey?"; then
    error "Aborting subkey transfer."
    exit 1
fi

# Transfer: key 1 (sign) -> slot 1, key 2 (encrypt) -> slot 2, key 3 (auth) -> slot 3
info "Transferring subkeys to YubiKey..."
gpg --command-fd=0 --pinentry-mode loopback --edit-key "$KEYFP" <<TRANSFER_EOF
key 1
keytocard
1
${CERTIFY_PASS}
${ADMIN_PIN}
key 1
key 2
keytocard
2
${CERTIFY_PASS}
${ADMIN_PIN}
key 2
key 3
keytocard
3
${CERTIFY_PASS}
${ADMIN_PIN}
save
TRANSFER_EOF

success "Subkeys transferred to YubiKey"

# Verify
echo ""
info "Verification - keys should show 'ssb>' (stub pointing to card):"
gpg -K "$KEYFP"
echo ""

info "Card status:"
gpg --card-status
echo ""

# Save metadata
save_metadata "$KEYFP" \
    "yubikey_serial" "$YUBIKEY_SERIAL" \
    "yubikey_model" "$YUBIKEY_MODEL" \
    "provisioned" "$(date -u +%Y-%m-%dT%H:%M:%SZ)"

success "YubiKey provisioning complete"
