#!/usr/bin/env bash
#MISE description="Factory reset YubiKey OpenPGP applet (DESTRUCTIVE)"
set -euo pipefail

source "$MISE_PROJECT_ROOT/lib/common.sh"

check_deps
detect_yubikey

echo ""
warn "=== YUBIKEY FACTORY RESET ==="
warn "This will DESTROY all OpenPGP keys on the YubiKey!"
warn ""
warn "YubiKey: ${YUBIKEY_MODEL} (serial: ${YUBIKEY_SERIAL})"
echo ""

# Show current card status
info "Current card status:"
gpg --card-status 2>/dev/null || warn "Could not read card status"
echo ""

# Double confirmation
if ! confirm "Are you sure you want to factory reset this YubiKey?"; then
    info "Aborted."
    exit 0
fi

echo ""
warn "THIS CANNOT BE UNDONE."
if ! confirm "Type 'y' again to confirm DESTRUCTIVE reset"; then
    info "Aborted."
    exit 0
fi

# Reset OpenPGP applet
info "Resetting OpenPGP applet..."
ykman openpgp reset --force

success "YubiKey OpenPGP applet reset to factory defaults"

echo ""
info "Post-reset card status (should show default state):"
gpg --card-status 2>/dev/null || warn "Card status not yet available (reconnect YubiKey if needed)"
echo ""

info "Default PINs after reset:"
info "  User PIN:  123456"
info "  Admin PIN: 12345678"
echo ""
success "YubiKey reset complete"
