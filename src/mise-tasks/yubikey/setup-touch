#!/usr/bin/env bash
#MISE description="Configure YubiKey touch policy for OpenPGP operations"
#USAGE flag "--admin-pin <pin>" help="YubiKey admin PIN (prompted if omitted)"
#USAGE flag "--policy <policy>" default="on" help="Touch policy: on, off, fixed, cached, cached-fixed"
set -euo pipefail

# shellcheck source=../../lib/common.sh
source "$MISE_PROJECT_ROOT/lib/common.sh"

check_ykman
detect_yubikey

if ! is_yubikey5; then
    error "Touch policy requires YubiKey 5 or later"
    exit 1
fi

ADMIN_PIN="${usage_admin_pin:-}"
POLICY="${usage_policy:-on}"

if [[ -z "$ADMIN_PIN" ]] && ! is_batch; then
    read -r -s -p "Enter YubiKey Admin PIN: " ADMIN_PIN
    echo ""
elif [[ -z "$ADMIN_PIN" ]]; then
    error "--admin-pin required in batch mode"
    exit 1
fi

info "Setting touch policy to '${POLICY}' for sig, dec, aut..."
for op in sig dec aut; do
    ykman openpgp keys set-touch "$op" "$POLICY" <<< "$ADMIN_PIN"
done
success "Touch policy set to '${POLICY}'"
