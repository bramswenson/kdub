#!/usr/bin/env bash
#MISE description="Factory reset OpenPGP card applet (DESTRUCTIVE)"
#USAGE flag "--force" help="Skip confirmation prompts"
set -euo pipefail

# shellcheck source=../../lib/common.sh
source "$MISE_PROJECT_ROOT/lib/common.sh"

check_card_deps

echo ""
warn "=== CARD FACTORY RESET ==="
warn "This will DESTROY all OpenPGP keys on the card!"
echo ""
gpg --card-status 2>/dev/null || warn "Could not read card status"
echo ""

if [[ "${usage_force:-false}" != "true" ]]; then
    confirm "Are you sure?" || { info "Aborted."; exit 0; }
    confirm "THIS CANNOT BE UNDONE. Confirm again?" || { info "Aborted."; exit 0; }
fi

info "Resetting card..."
gpg --command-fd=0 --pinentry-mode loopback --edit-card <<EOF
admin
factory-reset
y
yes
q
EOF

success "Card reset to factory defaults"
info "Default PINs: User=123456, Admin=12345678"
