#!/usr/bin/env bash
#MISE description="Show OpenPGP smart card status"
set -euo pipefail

# shellcheck source=../../lib/common.sh
source "$MISE_PROJECT_ROOT/lib/common.sh"

check_card_deps

echo ""
echo "=== OpenPGP Card Status ==="
echo ""
gpg --card-status 2>/dev/null || {
    warn "No OpenPGP card detected or card is not accessible."
    exit 1
}
echo ""
