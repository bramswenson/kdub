#!/usr/bin/env bash
#MISE description="Install required packages on Tails OS (must run each boot)"
set -euo pipefail

# shellcheck source=../../lib/common.sh
source "$MISE_PROJECT_ROOT/lib/common.sh"

if ! is_tails; then
    error "This task is only for Tails OS. Use 'mise run setup:install-deps' instead."
    exit 1
fi

warn "==========================================="
warn "  Tails: Install Every Time"
warn "  Tails resets installed packages on reboot."
warn "  Run this task after each Tails boot."
warn "==========================================="
echo ""

info "Installing packages via apt..."
sudo apt-get update -qq
sudo apt-get install -y --no-install-recommends \
    gnupg scdaemon pcscd libccid \
    yubikey-manager \
    jq secure-delete

# Start pcscd
if ! pgrep -x pcscd &>/dev/null; then
    info "Starting pcscd..."
    sudo systemctl start pcscd 2>/dev/null || sudo pcscd 2>/dev/null || true
fi

# Verify
for cmd in gpg gpg-card scdaemon jq ykman; do
    if command -v "$cmd" &>/dev/null; then
        success "$cmd: $(command -v "$cmd")"
    else
        warn "$cmd: not found (may not be needed)"
    fi
done

success "Tails dependencies installed"
