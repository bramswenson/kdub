#!/usr/bin/env bash
#MISE description="Wire yk-gpg XDG directories into Tails persistent storage"
set -euo pipefail

# shellcheck source=../../lib/common.sh
source "$MISE_PROJECT_ROOT/lib/common.sh"

if ! is_tails; then
    error "This task is only for Tails OS"
    exit 1
fi

PERSISTENT_DIR="/home/amnesia/Persistent/yk-gpg"
DATA_DIR="$(yk_gpg_data_dir)"
CONFIG_DIR="$(yk_gpg_config_dir)"
DOTFILES_ROOT="/live/persistence/TailsData_unlocked/dotfiles"

# Create persistent data directory
info "Creating persistent data directory: $PERSISTENT_DIR"
mkdir -p "$PERSISTENT_DIR/identities" "$PERSISTENT_DIR/backups"
chmod 700 "$PERSISTENT_DIR"

# Symlink XDG data dir to persistent storage
if [[ -L "$DATA_DIR" ]]; then
    info "Data dir already symlinked: $(readlink "$DATA_DIR")"
elif [[ -d "$DATA_DIR" ]]; then
    warn "Data dir exists and is not a symlink: $DATA_DIR"
    warn "Moving contents to $PERSISTENT_DIR and replacing with symlink..."
    cp -a "$DATA_DIR"/* "$PERSISTENT_DIR/" 2>/dev/null || true
    rm -rf "$DATA_DIR"
    ln -sf "$PERSISTENT_DIR" "$DATA_DIR"
else
    mkdir -p "$(dirname "$DATA_DIR")"
    ln -sf "$PERSISTENT_DIR" "$DATA_DIR"
fi
success "Data dir → $PERSISTENT_DIR"

# Stage config files in Tails dotfiles persistence
if [[ -d "$DOTFILES_ROOT" ]]; then
    DOTFILES_CONFIG="${DOTFILES_ROOT}/.config/yk-gpg"
    mkdir -p "$DOTFILES_CONFIG"
    for f in gpg.conf gpg-agent.conf scdaemon.conf dirmngr.conf; do
        [[ -f "${CONFIG_DIR}/$f" ]] && cp "${CONFIG_DIR}/$f" "${DOTFILES_CONFIG}/$f"
    done
    success "Config files staged in dotfiles persistence (active on next boot)"
else
    warn "Dotfiles persistence not enabled. Enable it in Tails Persistent Storage settings."
fi

success "Tails persistence setup complete"
