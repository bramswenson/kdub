#!/usr/bin/env bash
#MISE description="List all managed GPG identities and their status"
set -euo pipefail

# shellcheck source=../../lib/common.sh
source "$MISE_PROJECT_ROOT/lib/common.sh"

echo ""
echo "=== Managed GPG Identities ==="
echo ""

NOW="$(date +%s)"
WARN_THRESHOLD=$((90 * 86400))  # 90 days in seconds

IDENTITIES_DIR="$(yk_gpg_data_dir)/identities"

# Parse secret keys
gpg --with-colons --list-secret-keys 2>/dev/null | while IFS=: read -r type _trust _len algo keyid created expires _rest; do
    case "$type" in
        sec)
            echo "---"
            uid="$(gpg --with-colons --list-secret-keys "$keyid" 2>/dev/null | grep '^uid:' | head -1 | cut -d: -f10)"
            fp="$(gpg --with-colons --list-secret-keys "$keyid" 2>/dev/null | grep '^fpr:' | head -1 | cut -d: -f10)"
            echo "Identity:    $uid"
            echo "Key ID:      0x${keyid}"
            echo "Fingerprint: $fp"
            echo "Algorithm:   $algo"
            if [[ -n "$created" ]]; then
                # Portable date: try macOS epoch format, then GNU format
                echo "Created:     $(date -r "$created" +%Y-%m-%d 2>/dev/null || date -d "@$created" +%Y-%m-%d 2>/dev/null || echo "$created")"
            fi

            # Check metadata for card info
            if [[ -n "$fp" && -f "${IDENTITIES_DIR}/${fp}.json" ]]; then
                yk_serial="$(jq -r '.card_serial // .yubikey_serial // ""' "${IDENTITIES_DIR}/${fp}.json" 2>/dev/null || true)"
                if [[ -n "$yk_serial" ]]; then
                    echo "Card:        serial $yk_serial"
                fi
            fi
            ;;
        ssb)
            status=""
            if [[ -n "$expires" && "$expires" -gt 0 ]]; then
                exp_date="$(date -r "$expires" +%Y-%m-%d 2>/dev/null || date -d "@$expires" +%Y-%m-%d 2>/dev/null || echo "$expires")"
                remaining=$((expires - NOW))
                if [[ $remaining -le 0 ]]; then
                    status=" \033[1;31m[EXPIRED]\033[0m"
                elif [[ $remaining -le $WARN_THRESHOLD ]]; then
                    days=$((remaining / 86400))
                    status=" \033[1;33m[expires in ${days}d]\033[0m"
                fi
                printf "  Subkey:    %s  algo:%s  expires:%s%b\n" "$keyid" "$algo" "$exp_date" "$status"
            else
                printf "  Subkey:    %s  algo:%s  expires:never\n" "$keyid" "$algo"
            fi
            ;;
    esac
done

echo ""
echo "---"

# Show card status if a card is present
if gpg --card-status &>/dev/null; then
    echo ""
    echo "=== Connected Smart Card ==="
    echo ""
    gpg --card-status 2>/dev/null | grep -E '(Name|Serial|Signature key|Encryption key|Authentication key)' || true
fi

echo ""
