#!/usr/bin/env bash
#MISE description="Create a new GPG identity with certify key and subkeys"
#USAGE arg "identity" help="Identity string, e.g. 'Name <email>'"
#USAGE flag "--key-type <type>" help="Key algorithm: ed25519 or rsa4096 (auto-detected from YubiKey if omitted)"
#USAGE flag "--expiration <exp>" default="2y" help="Subkey expiration (e.g. 2y, 2027-07-01)"
#USAGE flag "--passphrase <pass>" help="Set your own certify key passphrase (prompted interactively if omitted)"
set -euo pipefail

# shellcheck source=../../lib/common.sh
source "$MISE_PROJECT_ROOT/lib/common.sh"

IDENTITY="${usage_identity:?Identity argument required}"
KEY_TYPE="${usage_key_type:-}"
EXPIRATION="${usage_expiration:-${YK_GPG_EXPIRATION:-2y}}"

check_gpg_deps

# Auto-detect key type from YubiKey if not specified
if [[ -z "$KEY_TYPE" ]]; then
    if ykman info &>/dev/null; then
        detect_yubikey
        KEY_TYPE="$(best_key_type)"
        info "Auto-detected key type: $KEY_TYPE"
    else
        KEY_TYPE="${YK_GPG_KEY_TYPE:-rsa4096}"
        info "Using key type: $KEY_TYPE"
    fi
fi

# Determine GPG algorithm strings
case "$KEY_TYPE" in
    ed25519)
        CERTIFY_ALGO="ed25519"
        SIGN_ALGO="ed25519"
        ENCRYPT_ALGO="cv25519"
        AUTH_ALGO="ed25519"
        ;;
    rsa4096)
        CERTIFY_ALGO="rsa4096"
        SIGN_ALGO="rsa4096"
        ENCRYPT_ALGO="rsa4096"
        AUTH_ALGO="rsa4096"
        ;;
    *)
        error "Unsupported key type: $KEY_TYPE (use ed25519 or rsa4096)"
        exit 1
        ;;
esac

# Set up GNUPGHOME — use ephemeral tmpfs unless GNUPGHOME is already set
if [[ -z "${GNUPGHOME:-}" || "$GNUPGHOME" == "$HOME/.gnupg" ]]; then
    setup_temp_gnupghome
    trap cleanup_temp_gnupghome EXIT
else
    info "Using existing GNUPGHOME: $GNUPGHOME"
fi

# Get certify key passphrase
if [[ -n "${usage_passphrase:-}" ]]; then
    CERTIFY_PASS="$usage_passphrase"
    info "Using provided passphrase"
elif is_batch; then
    error "--passphrase is required in batch mode"
    exit 1
else
    echo ""
    read -r -s -p "Enter certify key passphrase (leave empty to auto-generate): " CERTIFY_PASS
    echo ""
    if [[ -z "$CERTIFY_PASS" ]]; then
        CERTIFY_PASS="$(generate_passphrase 24)"
        echo ""
        echo "=============================================="
        echo "  CERTIFY KEY PASSPHRASE - RECORD THIS NOW"
        echo "=============================================="
        echo ""
        echo "  $CERTIFY_PASS"
        echo ""
        echo "=============================================="
        echo ""
    else
        read -r -s -p "Confirm passphrase: " CERTIFY_PASS_CONFIRM
        echo ""
        if [[ "$CERTIFY_PASS" != "$CERTIFY_PASS_CONFIRM" ]]; then
            error "Passphrases do not match"
            exit 1
        fi
    fi
    warn "This passphrase protects your master certify key."
    warn "You will need it to manage subkeys in the future."
    echo ""
fi

# Create certify key (no expiration)
info "Creating certify key for: $IDENTITY"
echo "$CERTIFY_PASS" | gpg --batch --passphrase-fd 0 \
    --quick-generate-key "$IDENTITY" "$CERTIFY_ALGO" cert never

# Extract key ID and fingerprint
KEYFP="$(gpg --with-colons --list-keys "$IDENTITY" | grep '^fpr:' | head -1 | cut -d: -f10)"
KEYID="0x${KEYFP: -16}"

success "Certify key created: $KEYID"
info "Fingerprint: $KEYFP"

# Create subkeys with expiration
info "Creating sign subkey ($SIGN_ALGO, expires: $EXPIRATION)..."
echo "$CERTIFY_PASS" | gpg --batch --pinentry-mode loopback --passphrase-fd 0 \
    --quick-add-key "$KEYFP" "$SIGN_ALGO" sign "$EXPIRATION"

info "Creating encrypt subkey ($ENCRYPT_ALGO, expires: $EXPIRATION)..."
echo "$CERTIFY_PASS" | gpg --batch --pinentry-mode loopback --passphrase-fd 0 \
    --quick-add-key "$KEYFP" "$ENCRYPT_ALGO" encr "$EXPIRATION"

info "Creating auth subkey ($AUTH_ALGO, expires: $EXPIRATION)..."
echo "$CERTIFY_PASS" | gpg --batch --pinentry-mode loopback --passphrase-fd 0 \
    --quick-add-key "$KEYFP" "$AUTH_ALGO" auth "$EXPIRATION"

success "All subkeys created"

# Display full key listing
echo ""
info "Key listing:"
gpg -K
echo ""

# Save identity metadata
save_metadata "$KEYFP" \
    "identity" "$IDENTITY" \
    "fingerprint" "$KEYFP" \
    "keyid" "$KEYID" \
    "key_type" "$KEY_TYPE" \
    "expiration" "$EXPIRATION" \
    "created" "$(date -u +%Y-%m-%dT%H:%M:%SZ)"

# In batch mode, skip the backup chain
if ! is_batch && confirm "Continue to backup keys?" "y"; then
    info "Invoking backup task..."
    mise run gpg:backup -- "$KEYID"
else
    if ! is_batch; then
        warn "Remember to back up your keys before rebooting!"
        warn "Run: mise run gpg:backup -- $KEYID"
    fi
fi
