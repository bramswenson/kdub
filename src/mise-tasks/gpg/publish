#!/usr/bin/env bash
#MISE description="Publish GPG public key to keyservers, GitHub, or export for WKD"
#USAGE arg "keyid" help="Key ID or fingerprint to publish"
#USAGE flag "--keyserver" help="Upload to keys.openpgp.org (requires email verification)"
#USAGE flag "--github" help="Upload to GitHub (requires GITHUB_TOKEN env var)"
#USAGE flag "--wkd <webroot>" help="Export for Web Key Directory to given web root path"
#USAGE flag "--file <path>" help="Export public key .asc to a file path"
#USAGE flag "--all" help="Publish to all configured destinations"
set -euo pipefail

# shellcheck source=../../lib/common.sh
source "$MISE_PROJECT_ROOT/lib/common.sh"

setup_networking

KEYID="${usage_keyid:?Key ID argument required}"
KEYSERVER="${usage_keyserver:-false}"
GITHUB="${usage_github:-false}"
WKD="${usage_wkd:-}"
FILE="${usage_file:-}"
ALL="${usage_all:-false}"

# Verify key exists
KEYFP="$(gpg --with-colons --list-keys "$KEYID" 2>/dev/null | grep '^fpr:' | head -1 | cut -d: -f10)"
if [[ -z "$KEYFP" ]]; then
    error "Key not found: $KEYID"
    exit 1
fi

info "Publishing key $KEYID (fingerprint: $KEYFP)"

# If --all, enable keyserver and github
if [[ "$ALL" == "true" ]]; then
    KEYSERVER="true"
    GITHUB="true"
fi

# In batch mode, require at least one flag
if is_batch && [[ "$KEYSERVER" != "true" && "$GITHUB" != "true" && -z "$WKD" && -z "$FILE" ]]; then
    error "In batch mode, specify at least one destination flag (--keyserver, --github, --wkd, --file, --all)"
    exit 1
fi

# If no flags given, interactively ask
if [[ "$KEYSERVER" != "true" && "$GITHUB" != "true" && -z "$WKD" && -z "$FILE" ]]; then
    echo ""
    echo "Where would you like to publish your public key?"
    echo ""
    if confirm "Upload to keys.openpgp.org?"; then
        KEYSERVER="true"
    fi
    if confirm "Upload to GitHub (requires GITHUB_TOKEN)?"; then
        GITHUB="true"
    fi
    echo ""
    read -r -p "Export to file path (leave empty to skip): " FILE
    echo ""
    read -r -p "WKD web root path (leave empty to skip): " WKD
fi

PUBLISHED=false

# --- Keyserver ---
if [[ "$KEYSERVER" == "true" ]]; then
    info "Uploading to keys.openpgp.org..."
    gpg --keyserver hkps://keys.openpgp.org --send-key "$KEYFP"
    success "Key uploaded to keys.openpgp.org"
    warn "Email verification required for identity to be discoverable."
    PUBLISHED=true
fi

# --- GitHub ---
if [[ "$GITHUB" == "true" ]]; then
    if [[ -z "${GITHUB_TOKEN:-}" ]]; then
        error "GITHUB_TOKEN environment variable is required for GitHub upload"
        exit 1
    fi

    info "Uploading to GitHub..."
    PUBKEY="$(gpg --armor --export "$KEYFP")"

    RESPONSE="$(jq -n --arg key "$PUBKEY" '{armored_public_key: $key}' | \
        curl -s -w "\n%{http_code}" -X POST \
            -H "Accept: application/vnd.github+json" \
            -H "Authorization: Bearer $GITHUB_TOKEN" \
            https://api.github.com/user/gpg_keys \
            -d @-)"

    HTTP_CODE="$(echo "$RESPONSE" | tail -1)"
    BODY="$(echo "$RESPONSE" | sed '$d')"

    case "$HTTP_CODE" in
        201)
            success "Key uploaded to GitHub"
            ;;
        422)
            warn "Key may already exist on GitHub"
            echo "$BODY" | jq -r '.message // .errors[0].message // "Unknown error"' 2>/dev/null || echo "$BODY"
            ;;
        *)
            error "GitHub upload failed (HTTP $HTTP_CODE)"
            echo "$BODY" | jq -r '.message // .' 2>/dev/null || echo "$BODY"
            exit 1
            ;;
    esac
    PUBLISHED=true
fi

# --- WKD ---
if [[ -n "$WKD" ]]; then
    EMAIL="$(gpg --with-colons --list-keys "$KEYFP" | grep '^uid:' | head -1 | cut -d: -f10 | sed 's/.*<\(.*\)>.*/\1/')"
    if [[ -z "$EMAIL" || "$EMAIL" == *"<"* ]]; then
        error "Could not extract email address from key UID"
        exit 1
    fi

    DOMAIN="${EMAIL#*@}"
    HASH="$(gpg-wks-client --print-wkd-hash "$EMAIL" 2>/dev/null | cut -d' ' -f1)"
    if [[ -z "$HASH" ]]; then
        error "Could not compute WKD hash (is gpg-wks-client available?)"
        exit 1
    fi

    WKD_DIR="${WKD}/.well-known/openpgpkey/hu"
    mkdir -p "$WKD_DIR"
    gpg --no-armor --export "$KEYFP" > "${WKD_DIR}/${HASH}"
    touch "${WKD}/.well-known/openpgpkey/policy"

    success "WKD key exported to ${WKD_DIR}/${HASH}"
    echo ""
    info "WKD setup notes:"
    echo "  - Domain: $DOMAIN"
    echo "  - Serve .well-known/openpgpkey/ over HTTPS"
    echo "  - Set Content-Type: application/octet-stream for hu/ files"
    echo "  - Ensure Access-Control-Allow-Origin: * header"
    PUBLISHED=true
fi

# --- File export ---
if [[ -n "$FILE" ]]; then
    gpg --armor --export "$KEYFP" > "$FILE"
    success "Public key exported to $FILE"
    PUBLISHED=true
fi

if [[ "$PUBLISHED" != "true" ]]; then
    warn "No destinations selected. Nothing published."
    exit 1
fi

echo ""
success "Publishing complete"
