#!/usr/bin/env bash
#MISE description="Generate new subkeys and transfer to YubiKey (full key rotation)"
#USAGE arg "identity" help="Identity name or key ID"
#USAGE flag "--key-type <type>" help="Key algorithm for new subkeys"
#USAGE flag "--expiration <exp>" default="2y" help="New subkey expiration"
#USAGE flag "--passphrase <pass>" help="Certify key passphrase (required in batch mode)"
#USAGE flag "--revoke-old" help="Revoke old subkeys without prompting"
set -euo pipefail

# shellcheck source=../../lib/common.sh
source "$MISE_PROJECT_ROOT/lib/common.sh"

IDENTITY="${usage_identity:?Identity argument required}"
KEY_TYPE="${usage_key_type:-${YK_GPG_KEY_TYPE:-}}"
EXPIRATION="${usage_expiration:-${YK_GPG_EXPIRATION:-2y}}"
REVOKE_OLD="${usage_revoke_old:-false}"

check_gpg_deps

KEYID="$(validate_identity "$IDENTITY")" || exit 1
KEYFP="$(gpg --with-colons --list-keys "$KEYID" 2>/dev/null | grep '^fpr:' | head -1 | cut -d: -f10)"

info "Rotating subkeys for: $IDENTITY"
info "Key: $KEYID"

# Auto-detect key type if not specified
if [[ -z "$KEY_TYPE" ]]; then
    if ykman info &>/dev/null; then
        detect_yubikey
        KEY_TYPE="$(best_key_type)"
        info "Auto-detected key type: $KEY_TYPE"
    else
        KEY_TYPE="${YK_GPG_KEY_TYPE:-rsa4096}"
        warn "No YubiKey detected; defaulting to $KEY_TYPE"
    fi
fi

# Determine algorithm strings
case "$KEY_TYPE" in
    ed25519) SIGN_ALGO="ed25519"; ENCRYPT_ALGO="cv25519"; AUTH_ALGO="ed25519" ;;
    rsa4096) SIGN_ALGO="rsa4096"; ENCRYPT_ALGO="rsa4096"; AUTH_ALGO="rsa4096" ;;
    *) error "Unsupported key type: $KEY_TYPE"; exit 1 ;;
esac

# Get certify key passphrase
if [[ -n "${usage_passphrase:-}" ]]; then
    CERTIFY_PASS="$usage_passphrase"
elif is_batch; then
    error "--passphrase is required in batch mode"
    exit 1
else
    read -r -s -p "Enter certify key passphrase: " CERTIFY_PASS
    echo ""
fi

# Optionally revoke old subkeys
if [[ "$REVOKE_OLD" == "true" ]] || { ! is_batch && confirm "Revoke old subkeys?"; }; then
    info "Revoking old subkeys..."
    NUM_SUBKEYS="$(gpg --with-colons --list-keys "$KEYFP" | grep -c '^sub:')"
    for i in $(seq 1 "$NUM_SUBKEYS"); do
        gpg --no-tty --command-fd=0 --pinentry-mode loopback --passphrase-fd 3 --edit-key "$KEYFP" 3<<< "$CERTIFY_PASS" <<REVOKE_EOF
key $i
revkey
y
0

y
save
REVOKE_EOF
    done
    success "Old subkeys revoked"
fi

# Create new subkeys
info "Creating new sign subkey ($SIGN_ALGO, expires: $EXPIRATION)..."
echo "$CERTIFY_PASS" | gpg --batch --pinentry-mode loopback --passphrase-fd 0 \
    --quick-add-key "$KEYFP" "$SIGN_ALGO" sign "$EXPIRATION"

info "Creating new encrypt subkey ($ENCRYPT_ALGO, expires: $EXPIRATION)..."
echo "$CERTIFY_PASS" | gpg --batch --pinentry-mode loopback --passphrase-fd 0 \
    --quick-add-key "$KEYFP" "$ENCRYPT_ALGO" encr "$EXPIRATION"

info "Creating new auth subkey ($AUTH_ALGO, expires: $EXPIRATION)..."
echo "$CERTIFY_PASS" | gpg --batch --pinentry-mode loopback --passphrase-fd 0 \
    --quick-add-key "$KEYFP" "$AUTH_ALGO" auth "$EXPIRATION"

success "New subkeys created"

# Display key listing
echo ""
gpg -K "$KEYFP"
echo ""

# Export updated public key
BACKUP_DIR="$(yk_gpg_data_dir)/backups/${KEYFP}"
if [[ -d "$BACKUP_DIR" ]]; then
    info "Exporting updated public key..."
    gpg --armor --export "$KEYFP" > "${BACKUP_DIR}/public-key.asc"
fi

# Update metadata
save_metadata "$KEYFP" \
    "rotated" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    "key_type" "$KEY_TYPE" \
    "expiration" "$EXPIRATION"

# Offer to backup (skip in batch mode — caller handles it)
if ! is_batch && confirm "Update backup?" "y"; then
    mise run gpg:backup -- "$KEYID"
fi

# Offer to provision card (skip in batch mode — caller handles it)
if ! is_batch && confirm "Provision new subkeys to card?"; then
    mise run card:provision -- "$KEYID"
fi

echo ""
warn "Remember to distribute the updated public key to contacts/keyservers."
success "Key rotation complete for $KEYID"
