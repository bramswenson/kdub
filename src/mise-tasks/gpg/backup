#!/usr/bin/env bash
#MISE description="Backup GPG keys to data directory"
#USAGE arg "keyid" help="Key ID to backup (e.g. 0xABCD1234)"
#USAGE flag "--passphrase <pass>" help="Certify key passphrase (required in batch mode for secret export)"
set -euo pipefail

# shellcheck source=../../lib/common.sh
source "$MISE_PROJECT_ROOT/lib/common.sh"

KEYID="${usage_keyid:?Key ID argument required}"
CERTIFY_PASS="${usage_passphrase:-}"

# Get fingerprint
KEYFP="$(gpg --with-colons --list-keys "$KEYID" 2>/dev/null | grep '^fpr:' | head -1 | cut -d: -f10)"
if [[ -z "$KEYFP" ]]; then
    error "Key not found: $KEYID"
    exit 1
fi

info "Backing up key: $KEYID (fingerprint: $KEYFP)"

# Create backup directory
BACKUP_DIR="$(yk_gpg_data_dir)/backups/${KEYFP}"
mkdir -p "$BACKUP_DIR"
chmod 700 "$BACKUP_DIR"

# Build gpg export flags
GPG_EXPORT_FLAGS=(--armor)
if [[ -n "$CERTIFY_PASS" ]]; then
    GPG_EXPORT_FLAGS+=(--batch --pinentry-mode loopback --passphrase-fd 3)
fi

# Export keys
info "Exporting certify key (secret)..."
gpg "${GPG_EXPORT_FLAGS[@]}" --export-secret-keys "$KEYFP" \
    3<<< "$CERTIFY_PASS" > "${BACKUP_DIR}/certify-key.asc"

info "Exporting subkeys (secret)..."
gpg "${GPG_EXPORT_FLAGS[@]}" --export-secret-subkeys "$KEYFP" \
    3<<< "$CERTIFY_PASS" > "${BACKUP_DIR}/subkeys.asc"

info "Exporting public key..."
gpg --armor --export "$KEYFP" > "${BACKUP_DIR}/public-key.asc"

info "Exporting ownertrust..."
gpg --export-ownertrust > "${BACKUP_DIR}/ownertrust.txt"

# Generate revocation cert if not present
if [[ ! -f "${BACKUP_DIR}/revocation-cert.asc" ]]; then
    info "Generating revocation certificate..."
    if [[ -n "$CERTIFY_PASS" ]]; then
        printf "y\n0\n\ny\n" | gpg --command-fd 0 --no-tty --pinentry-mode loopback \
            --passphrase-fd 3 \
            --yes --output "${BACKUP_DIR}/revocation-cert.asc" --gen-revoke "$KEYFP" \
            3<<< "$CERTIFY_PASS"
    else
        gpg --yes --output "${BACKUP_DIR}/revocation-cert.asc" --gen-revoke "$KEYFP"
    fi
fi

success "Keys exported to: $BACKUP_DIR"

# Update metadata
save_metadata "$KEYFP" \
    "backed_up" "$(date -u +%Y-%m-%dT%H:%M:%SZ)"

echo ""
success "Backup complete for $KEYID"
