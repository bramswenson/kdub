#!/usr/bin/env bash
#MISE description="Initialize yk-gpg directories and config files"
set -euo pipefail

# shellcheck source=../../lib/common.sh
source "$MISE_PROJECT_ROOT/lib/common.sh"

CONFIG_DIR="$(yk_gpg_config_dir)"
DATA_DIR="$(yk_gpg_data_dir)"
STATE_DIR="$(yk_gpg_state_dir)"

info "Platform: $PLATFORM"
info "Config:   $CONFIG_DIR"
info "Data:     $DATA_DIR"

mkdir -p "$CONFIG_DIR" "$DATA_DIR/identities" "$DATA_DIR/backups"
chmod 700 "$CONFIG_DIR" "$DATA_DIR"

if [[ -n "$STATE_DIR" ]] && ! is_tails; then
    mkdir -p "$STATE_DIR"
fi

# Install GPG configs
# MISE_PROJECT_ROOT points to src/ when run via src/mise.toml
SRC_ROOT="${MISE_PROJECT_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)}"
cp "${SRC_ROOT}/config/gpg.conf" "${CONFIG_DIR}/gpg.conf"
generate_gpg_agent_conf "$CONFIG_DIR"
generate_scdaemon_conf "$CONFIG_DIR"

if [[ -n "${YK_GPG_TOR_PROXY:-}" && -f "${SRC_ROOT}/config/dirmngr.conf" ]]; then
    cp "${SRC_ROOT}/config/dirmngr.conf" "${CONFIG_DIR}/dirmngr.conf"
    info "Installed dirmngr.conf (Tor proxy: $YK_GPG_TOR_PROXY)"
fi

success "yk-gpg initialized"
echo ""
info "Next: run 'mise run setup:install-deps' to install system packages"
